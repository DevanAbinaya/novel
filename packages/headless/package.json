{
  "name": "novel",
  "version": "1.0.0",
  "description": "Notion-style WYSIWYG editor with AI-powered autocompletions",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "build": "tsup",
    "lint": "biome lint ./src",
    "format": "biome format ./src ",
    "prepare": "npm run build"
  },
  "sideEffects": false,
  "peerDependencies": {
    "react": ">=18"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.7.6",
    "@radix-ui/react-slot": "^1.1.1",
    "@tiptap/core": "^3.20.1",
    "@tiptap/extension-code-block-lowlight": "^3.20.1",
    "@tiptap/extension-color": "^3.20.1",
    "@tiptap/extension-highlight": "^3.20.1",
    "@tiptap/extension-horizontal-rule": "^3.20.1",
    "@tiptap/extension-image": "^3.20.1",
    "@tiptap/extension-link": "^3.20.1",
    "@tiptap/extension-list": "^3.20.1",
    "@tiptap/extension-text-style": "^3.20.1",
    "@tiptap/extension-underline": "^3.20.1",
    "@tiptap/extension-youtube": "^3.20.1",
    "@tiptap/extensions": "^3.20.1",
    "@tiptap/pm": "^3.20.1",
    "@tiptap/react": "^3.20.1",
    "@tiptap/starter-kit": "^3.20.1",
    "@tiptap/suggestion": "^3.20.1",
    "@types/node": "^22.10.6",
    "cmdk": "^1.0.4",
    "jotai": "^2.11.0",
    "katex": "^0.16.20",
    "react-markdown": "^9.0.3",
    "react-moveable": "^0.56.0",
    "react-tweet": "^3.2.1",
    "tiptap-extension-global-drag-handle": "^0.1.18",
    "tiptap-markdown": "^0.9.0",
    "tunnel-rat": "^0.1.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/katex": "^0.16.7",
    "@types/react": "^18.2.55",
    "@types/react-dom": "18.2.19",
    "tsconfig": "workspace:*",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  },
  "author": "Steven Tey <stevensteel97@gmail.com>",
  "homepage": "https://novel.sh",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/steven-tey/novel.git"
  },
  "bugs": {
    "url": "https://github.com/steven-tey/novel/issues"
  },
  "keywords": [
    "ai",
    "novel",
    "editor",
    "markdown",
    "nextjs",
    "react"
  ]
}
